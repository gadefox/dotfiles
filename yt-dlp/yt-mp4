#!/bin/rc

fn filename {
  parts = `` (/) { echo -n $1 }
  echo -n $parts($#parts)
}

fn notify {
  notify-send --icon=/etc/xdg/awesome/icons/download.png '<b>'$1'</b>' $2
}

notify YouTube 'Video is downloading'
name = `{ yt-dlp --print after_move:filepath $1 }
name = `{ filename $name }

notify YouTube 'Video downloading is completed:<br>'$^name
exit 0
