#!/bin/rc

fn notify {
  notify-send --icon=/etc/xdg/awesome/icons/camera.png '<b>Web camera</b>' $1
}

fn devnr {
  sta = `{ cat /sys/devices/virtual/video4linux/video20/state }
  ~ $sta capture && echo -n 20 || echo -n 0
}

nr = `{ devnr }

if (~ $1 --play || ~ $1 1) {
  exec ffplay /dev/video$nr
}

if (~ $1 --flip || ~ $1 2) {
  if (~ $nr 0) {
    notify 'The image is turned upside down'
    exec ffmpeg -i /dev/video0 -vf vflip -f v4l2 /dev/video20
  }

  notify 'The image is already turned upside down'
  exit 0
}

if (~ $1 --stop || ~ $1 3) {
  pkill --full 'ffmpeg -i /dev/video0 -vf vflip -f v4l2 /dev/video20'
  notify 'Image flipping has been stopped'
  exit 0
}

echo parms: --play --flip --stop
exit 1
