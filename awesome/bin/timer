#!/bin/rc

fn minstr {
  str = $*' minute'
  ~$* 1 || str = $str's'
  echo -n $str
}

if (~ $* ()) {
  ps = `{ ps -d -o command,etimes | grep '^sleep' }
  parts = `` (' ') { echo -n $ps }
  rest = `{ calc 'floor(('$parts(2)'-'$parts(3)')/60)' }
  notify-send --icon=/etc/xdg/awesome/icons/timer.png '<b>Timer</b>' $^rest' minutes left'
  exit
}

str = `{ minstr $* }
notify-send --icon=/etc/xdg/awesome/icons/timer.png '<b>Timer</b>' 'Starting '$^str' countdown'
sleep `{ calc 60*$* }
notify-send --icon=/etc/xdg/awesome/icons/timer.png '<b>Time is up!</b>' $^str' countdown finished'
paplay --volume=43690 /usr/share/sounds/freedesktop/stereo/alarm-clock-elapsed.oga
