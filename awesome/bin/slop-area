#!/bin/rc

. /usr/local/libexec/rc/notify

notify_icon = screenshot
notify_title = Screenshot:

show_notify_id 'Select a window or region with two clicks.'
area = `(slop --bordersize=3 --shader=boxzoom --color='0.86,0.27,0.11,0.5' --nodrag --quiet --highlight)
if (~ $area ()) {
  show_notify_id 'Selection was cancelled by keystroke or right-click.'
  exit 1
}

dest = `(xdg-user-dir PICTURES) || $HOME
name = `(date +%F_%H-%M)^.png
file = $dest/$name
import -window root -crop $area $file

notify_actions $file 'Selection was saved to '$name' file.' 1 2 3
exit 0
