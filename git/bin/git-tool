#!/bin/rc

. /usr/local/libexec/rc/notify
. /usr/local/libexec/rc/string

notify_icon = git
notify_title = GitHub:

user = `(git config --global user.name)
~ $user () && exit 1

name = `pwd
name = `(get_filename $name)

fn is_rep {
  ~ `{ git rev-parse --is-inside-work-tree >[2]/dev/null } () || return
  show_notify `pwd' is not a git repository.'
  exit 1
}

if (~ $1 --status || ~ $1 1) {
  is_rep
  git = `` $nl (git status --porcelain)
  if (~ $git ()) {
    msg = 'nothing to commit, working tree clean.'
  } else {
    for (i in $git)
      ~ $i ' D'* && del = ($del +) || { ~ $i ' M'* && mod = ($mod +) }

    mod = `(plural_str $#mod file)
    add = `{ git ls-files --others --exclude-standard | wc -l }
    del = `(plural_str $#del file)
    msg = $^mod' modified, '$add' added, '$^del' deleted.'
  }

  show_notify 'Status: '$msg $name
  exit 0
}

if (~ $1 --checkin || ~ $1 2) {
  is_rep

  notify_sigexit+
  git add --all
  git commit -m 'Update all changes'
  git push origin HEAD
  notify_sigexit-

  show_notify 'All changes committed and pushed.' $name
  exit 0
}

if (~ $1 --init || ~ $1 3) {
  if (!~ `{ git rev-parse --is-inside-work-tree >[2]/dev/null } ()) {
    show_notify 'The repository has already been initialized.' $name
    exit 1
  }
  if (~ `{ curl -Is https://github.com/$user/$name | head -n 1 | awk '{ print $2 }' } 404) {
    show_notify 'Please manually create the GitHub repository.' $name
    exit 1
  }

  notify_sigexit+
  git init
  git add .
  git commit -m 'Initial commit'
  git remote add origin https://github.com/$user/$name.git
  git push -u origin main
  notify_sigexit-

  show_notify 'The repository has been successfully initialized.\nAll files have been uploaded.' $name
  exit 0
}


if (~ $1 --clean || ~ $1 4) {
  is_rep

  notify_sigexit+
  git checkout --orphan clean-main
  git add --all
  git commit -m 'Initial commit'
  git branch -M main
  git push --force origin main
  notify_sigexit-

  show_notify 'History cleared and new initial commit created.' $name
  exit 0
}

echo parms: --status --checkin --init --clean
exit 1