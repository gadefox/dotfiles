#!/bin/rc

. /usr/local/libexec/rc/notify
. /usr/local/libexec/rc/string

notify_icon = git
notify_title = GitHub:

name = `pwd
name = `(get_filename $name)

git = `{ git rev-parse --is-inside-work-tree >[2]/dev/null }
if (~ $git ()) {
  show_notify `pwd' is not a git repository.'
  exit 1
}

if (~ $1 --status || ~ $1 1) {
  git = `` $nl (git status --porcelain)
  if (~ $git ()) {
    msg = 'nothing to commit, working tree clean.'
  } else {
    for (i in $git)
      ~ $i ' D'* && del = ($del +) || { ~ $i ' M'* && mod = ($mod +) }

    mod = `(plural_str $#mod file)
    add = `{ git ls-files --others --exclude-standard | wc -l }
    del = `(plural_str $#del file)
    msg = $^mod' modified, '$add' added, '$^del' deleted.'
  }

  show_notify 'Status: '$msg $name
  exit 0
}

if (~ $1 --checkin || ~ $1 2) {
  notify_sigexit+
  git add --all
  git commit -m 'Update all changes'
  git push origin HEAD
  notify_sigexit-

  show_notify 'All changes committed and pushed.' $name
  exit 0
}

if (~ $1 --clean || ~ $1 3) {
  notify_sigexit+
  git checkout --orphan clean-main
  git add --all
  git commit -m 'Initial commit'
  git branch -M main
  git push --force origin main
  notify_sigexit-

  show_notify 'History cleared and new initial commit created.' $name
  exit 0
}

echo parms: --status --checkin --clean
exit 1