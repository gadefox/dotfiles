#!/bin/rc
. /usr/local/libexec/rc/notify
. /usr/local/libexec/rc/util
notify_icon = usb
notify_title = Device:

if (~ $1 1 || ~ $1 3) {
  usb = ``($nl) { lsblk -Jo TRAN,NAME,LABEL,SIZE | \
    jq -r '.blockdevices[] | select(.tran == "usb") | .children[]? | "\(.name): \(.label // "no-label") (\(.size))"' }

  ~ $usb () && notify_error 'No USB key found.'
  ~ $#usb 1 || usb = ``($nl) { echo $usb | dmenu -p 'Select USB' }
  usb = `(npart $usb : 1)

  ~ $1 1 && { echo $usb; exit 0 }
  * = (2 $usb)
}

if (~ $1 2) {
  usb = `{ lsblk -nro PATH,LABEL,MOUNTPOINT | grep $2 }
  if (~ $usb(3) ()) {
    new = `(udisksctl mount -b $usb(1))
    !~ $#new 4 || !~ $new(1) Mounted || !~ $new(2) $usb(1) || !~ $new(3) at || ~ $new(4) () && notify_error 'Error: '$^new $usb(2)

    dir = $new(4)
  } else {
    dir = $usb(3)
    msg = 'already '
  }

  msg = $usb(1)^' is '$msg'mounted at '$dir
  opt = `(notify_show $msg $usb(2) f=Folder)
  notify_xdg $dir $opt

  echo $usb(2)$dir
  exit 0
}

exit 1
