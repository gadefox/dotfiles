#!/bin/rc

fn notify {
  notify-send --icon=/etc/xdg/awesome/icons/camera.png '<b>Web camera</b>' $1
}

fn state {
  val = `{ cat /sys/devices/virtual/video4linux/video10/state }
  echo -n $val
}

if (~ $1 --play || ~ $1 1) {
  val = `{ state }
  if (~ $val capture) {
    exec ffplay /dev/video10
  }
  exec v4l2-flip ffplay /dev/video0
}

if (~ $1 --flip || ~ $1 2) {
  val = `{ state }
  if (~ $val capture) {
    notify 'The image is already turned upside down'
    exit 0
  }

  notify 'The image is turned upside down'
  exec ffmpeg -i /dev/video0 -vf vflip -f v4l2 /dev/video10
}

if (~ $1 --stop || ~ $1 3) {
  pkill --full 'ffmpeg -i /dev/video0 -vf vflip -f v4l2 /dev/video10'
  notify 'Image flipping has been stopped'
  exit 0
}

echo parms: --play --flip --stop
exit 1
