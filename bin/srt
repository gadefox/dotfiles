#!/bin/rc

if (~ $1 ()) {
  res = `{ dmenu -i -p Movie }
  ~ $res () && exit 1
  name = $^res
} else {
  name = $^1
}

nid = ()

fn notify {
  if (~ $nid ()) {
    nid = `{ notify-send --print-id --icon=/etc/xdg/awesome/icons/download.png '<b>Subtitle: '$name'</b>' $1 }
  } else {
    notify-send --replace-id=$nid --icon=/etc/xdg/awesome/icons/download.png '<b>Subtitle: '$name'</b>' $1
  }
}

notify 'Subtitle is downloading..'
dest = `{ xdg-user-dir VIDEOS } || $HOME
file = `{ subliminal --debug download $name --single --force --language=en --directory=$dest >[2=1] | grep INFO:subliminal.core:Saving | awk '{print $6}' | tr --delete '''' }
if (~ $file ()) {
  notify 'Subtitle can not be found.'
  exit 1
}

opt = `{ notify-send --icon=/etc/xdg/awesome/icons/download.png --action=1=Folder --action=2=Delete '<b>Subtitle: '$name'</b>' 'Downloaded 1 subtitle.' }
if (~ $opt 1) {
  exec xdg-open $dest
}

if (~ $opt 2) {
  rm $file
  notify 'The file has been deleted.'
  exit 1
}

echo -n $file
exit 0
