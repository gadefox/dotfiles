#!/bin/rc

. /usr/local/libexec/rc/notify

notify_icon = youtube
notify_title = Youtube:

show_notify 'Audio is downloading..'
file = `(yt-dlp --print after_move:filepath --extract-audio --audio-format mp3 $1)
name = `(get_filename $file)

notify_actions $file 'Audio downloading is completed:<br>'$name 1 2 3

exit 0
