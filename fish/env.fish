set --export XDG_CACHE_HOME "$HOME/.cache"
set --export XDG_CONFIG_HOME "$HOME/.config"
set --export XDG_DATA_HOME "$HOME/.local/share"
set --export XDG_DATA_DIRS "/usr/local/share:/usr/share"

set --path PATH "/usr/local/bin:/usr/bin"

set --export NNN_FIFO "/tmp/nnn.fifo"
set --export NNN_PLUG "d:dragon;i:imgview;p:preview"

set --export FZF_DEFAULT_OPTS "--prompt='❯ ' --pointer="
