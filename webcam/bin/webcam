#!/bin/rc

fn notify {
  notify-send --icon=/etc/xdg/awesome/icons/camera.png '<b>Virtual camera</b>' $1
}

fn state {
  val = `{ cat /sys/devices/virtual/video4linux/video10/state }
  echo -n $val
}

if (~ $1 --play || ~ $1 1) {
  val = `{ state }
  if (~ $val capture) {
    exec ffplay /dev/video10
  }
  exec v4l2-flip ffplay /dev/video0
}

if (~ $1 --flip || ~ $1 2) {
  val = `{ state }
  if (~ $val capture) {
    notify 'The image is already turned upside down'
    exit 0
  }

  notify 'Launching ffmpeg'
  exec ffmpeg -i /dev/video0 -vf vflip -f v4l2 /dev/video10
}

if (~ $1 --stop || ~ $1 3) {
  val = `{ state }
  if (~ $val capture) {
    pkill --full 'ffmpeg -i /dev/video0 -vf vflip -f v4l2 /dev/video10'
    notify 'Image flipping has been stopped'
  } else {
    notify 'The image is not turned upside down'
  }
  exit 0
}

if (~ $1 --info || ~ $1 4) {
  val = `{ state }
  if (!~ $val capture) {
    msg = 'not '
  }
  notify 'The image is '$msg'turned upside down'
  exit 0
}

echo parms: --play --flip --stop --info
exit 1
