#!/bin/rc

cache = $HOME/.cache/wspy
mkdir --parents $cache

config = $HOME/.config/wspy
mkdir --parents $config

config = $config/config
recipient = `{ jq --raw-output '.recipient' $config }
subject = `{ jq --raw-output '.subject' $config }
body = `{ jq --raw-output '.html_body' $config }
webs = `{ jq --raw-output '.web_list[]' $config }

fn handle {
  name = `{ echo -n $1 | sed -e 's|https\?://||' -e 's|^www\.||' -e 's|/$||' -e 's|/|_|g' -e 's|\.|_|g' }
  tmp = /tmp/$name.html
  wget --quiet --output-document=$tmp $1

  md5cur = `{ md5sum $tmp | awk '{print $1}' }
  rm $tmp

  md5file = $cache/$name
  md5old = `{ cat $md5file >[2]/dev/null }
  if (~ $md5old = $md5cur)
    exit

  echo -n $md5cur > $md5file

  replace = `{ echo -n $body | sed -e 's|%HREF%|'$1'|g' -e 's|%TEXT%|'$1'|g' }
  echo -n 'Subject: '$^subject$nl'Content-Type: text/html; charset=UTF-8'$nl$nl$^replace | msmtp $recipient
}

for (url in $webs)
  handle $url

exit 0
