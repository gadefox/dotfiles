set attach_save_dir = "~/downloads"
set certificate_file = "~/.cache/mutt/certificates"
set mailcap_path = "~/.config/mutt/mailcap"
set signature = "~/.config/mutt/signature"

set charset = "utf-8"
unset copy
set editor = "nvim"
set forward_quote
set include
set mail_check = 300
unset markers
set menu_scroll
set mime_forward
set pager_context = 3
set pager_index_lines = 10
set pager_stop
set query_command = "abook --mutt-query '%s'"
set reply_to
set sendmail = "msmtp"
set sort = reverse-threads
set sort_aux = last-date-received
set ssl_force_tls
set text_flowed
set tilde
unset use_from
unset wait_key

set crypt_autosign
set crypt_replysign
set crypt_replysignencrypted
set pgp_sign_as = 0x0D269DCFA58EA395
set pgp_timeout = 7200

set imap_authenticators = "oauthbearer:xoauth2"
set imap_oauth_refresh_command = "oauth2-gmail gadefoxren"
set imap_user = "gadefoxren@gmail.com"
set folder = "imaps://imap.gmail.com:993/"
set spoolfile = "+INBOX"
set postponed = "+[Gmail]/Drafts"
set record = "+[Gmail]/Sent Mail"
set trash = "+[Gmail]/Bin"

mailboxes =INBOX =Work "=[Gmail]/Sent Mail" =[Gmail]/Drafts =[Gmail]/Bin

bind index G imap-fetch-mail

macro generic,index,pager \ca "<shell-escape>abook<enter>" "launch abook"
macro index,pager A "<pipe-message>abook --add-email<enter>" "add the sender address to abook"

color attachment green default
color hdrdefault magenta default
color indicator default brightblack 
color normal color15 black
color signature color13 default
color status color14 default
color tilde magenta default 
color tree brightgreen default

color index magenta default "~N"
color index magenta default "~O"
color index color245 default "~D"
color index color10 default "~Q"
color index yellow default "~F"

color quoted green default
color quoted1 yellow default
color quoted2 cyan default
color quoted3 blue default
color quoted4 color12 default

color header color13 default ^From:

color body color11 default "[\-\.+_a-zA-Z0-9]+@[\-\.a-zA-Z0-9]+"
color body color11 default "(https|http|ftp)://[\-\.\,/+=&%~_:?\#a-zA-Z0-9]+"
color body color12 default "(^| |[-.[:alnum:]]+:+)~?\(/[-_.'[:alnum:]]+\)+/?"
